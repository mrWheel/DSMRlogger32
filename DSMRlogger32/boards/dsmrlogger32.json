{
  "name": "DSMRlogger32 (ESP32-WROVER, 4MB Flash, 4MB PSRAM)",
  "vendor": "Custom",
  "url": "https://willem.aandewiel.nl/index.php/2022/11/15/crisis-what-crisis/",
  "frameworks": ["arduino"],
  "platforms": ["espressif32"],

  "build": {
    "core": "esp32",
    "mcu": "esp32",
    "variant": "esp32",
    "f_cpu": "240000000L",
    "flash_mode": "qio",
    "f_flash": "80000000L",

    "extra_flags": [
      "-DBOARD_HAS_PSRAM"
    ]
  },

  "upload": {
    "flash_size": "4MB",
    "maximum_size": 1572864,
    "maximum_ram_size": 327680,
    "speed": 230400,
    "require_upload_port": true
  },

  "debug": {
    "openocd_target": "esp32.cfg"
  },

  "connectivity": [
    "wifi",
    "bluetooth"
  ]
}